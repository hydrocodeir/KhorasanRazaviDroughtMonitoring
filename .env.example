APP_ENV=development
POSTGRES_DB=drought
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/drought
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://0.0.0.0:8080,http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000

DATASETS_ROOT=F:\Datasets
SPI_CACHE_ROOT=./data/spi_cache

# AI chatbot configuration. Keep the real key only in your private .env.
NVIDIA_API_KEY=
NVIDIA_MODEL=openai/gpt-oss-120b
NVIDIA_MODELS=openai/gpt-oss-120b,nvidia/nemotron-3-super-120b-a12b,z-ai/glm-5.1,qwen/qwen3-next-80b-a3b-instruct,qwen/qwen3.5-397b-a17b,moonshotai/kimi-k2.6,minimaxai/minimax-m2.7,deepseek-ai/deepseek-v4-flash,google/gemma-4-31b-it
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
AI_TIMEOUT_SECONDS=60

POSTGRES_DB=drought
POSTGRES_USER=drought
POSTGRES_PASSWORD=change-me

DATABASE_URL=postgresql+psycopg2://drought:change-me@db:5432/drought

APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=https://khrw.werifum.ir,http://khrw.werifum.ir

# Paths used by docker-compose.prod.yml for /datasets and /spi-cache mounts.
# Replace these with the real host paths on the production machine.
DATASETS_ROOT=/mnt/f/Datasets
SPI_CACHE_ROOT=/mnt/f/Datasets/DroughtCache/polygon_spi

FRONTEND_PORT=23432

MAP_LIMIT_DEFAULT=2000
MAP_LIMIT_MAX=10000
CACHE_TTL_SHORT_SECONDS=300
CACHE_TTL_MEDIUM_SECONDS=900
CACHE_TTL_LONG_SECONDS=1800
CACHE_TTL_DAILY_SECONDS=86400

# AI chatbot configuration. Keep the real key only in your private .env/.env.prod.
NVIDIA_API_KEY=
NVIDIA_MODEL=openai/gpt-oss-120b
NVIDIA_MODELS=openai/gpt-oss-120b,nvidia/nemotron-3-super-120b-a12b,z-ai/glm-5.1,qwen/qwen3-next-80b-a3b-instruct,qwen/qwen3.5-397b-a17b,moonshotai/kimi-k2.6,minimaxai/minimax-m2.7,deepseek-ai/deepseek-v4-flash,google/gemma-4-31b-it
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
AI_TIMEOUT_SECONDS=60

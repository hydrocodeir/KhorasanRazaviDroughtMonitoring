{
  "input_csv": "${DATASETS_ROOT}/RazaviKhorasanStations.csv",
  "output_root": "data/import",
  "dataset_key": "razavi_khorasan_station_spi3",
  "title": "Razavi Khorasan Stations SPI-3 — Stations",
  "source_key": "razavi_khorasan_stations",
  "source_title": "Razavi Khorasan Stations",
  "boundary_key": "station",
  "boundary_title": "Stations",
  "scale": 3,
  "chunksize": 250000,
  "compression": "zstd",
  "encoding": "utf-8-sig",
  "minimum_reference_years": 20,
  "minimum_daily_coverage_ratio": 0.8,
  "reference_start": "1991-01",
  "reference_end": "2020-12",
  "fallback_reference_to_available": true,
  "station_id_column": "station_id",
  "station_name_column": "station_name",
  "lon_column": "lon",
  "lat_column": "lat",
  "elevation_column": "station_elevation",
  "date_column": "date",
  "precip_column": "rrr24"
}

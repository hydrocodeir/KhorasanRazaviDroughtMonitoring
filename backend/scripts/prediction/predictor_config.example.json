{
  "source": "terraclimate",
  "use_helpers": "yes",
  "output_root": "data/prediction/features",
  "bbox": "56.0,33.0,62.5,38.5",
  "baseline_start": "1981-01-01",
  "baseline_end": "2010-12-31",
  "enso_file": "/datasets/enso_nino34.csv",
  "helpers": [
    {
      "name": "precip",
      "enabled": true,
      "input": ["/datasets/TerraClimate/PPT"],
      "variable": "ppt",
      "output": "precip"
    },
    {
      "name": "soil_moisture",
      "enabled": true,
      "input": ["/datasets/TerraClimate/SOIL"],
      "variable": "soil",
      "output": "soil_moisture"
    },
    {
      "name": "pet",
      "enabled": true,
      "input": ["/datasets/TerraClimate/PET"],
      "variable": "pet",
      "output": "pet"
    },
    {
      "name": "tmin",
      "enabled": true,
      "input": ["/datasets/TerraClimate/TMIN"],
      "variable": "tmin",
      "output": "tmin"
    },
    {
      "name": "tmax",
      "enabled": true,
      "input": ["/datasets/TerraClimate/TMAX"],
      "variable": "tmax",
      "output": "tmax"
    }
  ]
}
